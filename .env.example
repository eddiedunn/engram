# Engram Configuration
# Copy to .env and customize

# Database (PostgreSQL with pgvector)
ENGRAM_DATABASE_URL=postgresql+asyncpg://engram:engram@localhost:5432/engram
ENGRAM_DB_POOL_SIZE=5
ENGRAM_DB_MAX_OVERFLOW=10

# Embedding Model
ENGRAM_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ENGRAM_EMBEDDING_DIMENSIONS=1024
ENGRAM_EMBEDDING_BATCH_SIZE=32

# API Server
ENGRAM_API_HOST=0.0.0.0
ENGRAM_API_PORT=8800
ENGRAM_API_RELOAD=false

# Logging
ENGRAM_LOG_LEVEL=INFO
ENGRAM_LOG_FORMAT=json
